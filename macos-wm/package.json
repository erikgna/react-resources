{
  "name": "macos-wm",
  "version": "0.1.0",
  "description": "Personal macOS window manager — keyboard-driven snap layouts",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "main/main.js",
  "scripts": {
    "build:swift": "cd swift-helper && swift build -c release",
    "start": "npm run build:swift && electron-forge start",
    "package": "npm run build:swift && electron-forge package"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "electron": "^41.2.1"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "extraFiles": [
          {
            "from": "swift-helper/.build/release/wm-helper",
            "to": "resources/wm-helper"
          }
        ]
      },
      "makers": []
    }
  }
}
