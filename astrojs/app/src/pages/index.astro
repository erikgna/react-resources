---
import { ViewTransitions } from "astro:transitions";
import StaticCounter from "../components/StaticCounter.astro";
import ReactCounter from "../components/ReactCounter.tsx";
import HydrationDemo from "../components/HydrationDemo.astro";
import StaticList from "../components/StaticList.astro";
import ReactList from "../components/ReactList.tsx";
import ContentDemo from "../components/ContentDemo.astro";
import SlotsDemo from "../components/SlotsDemo.astro";
import StoresDemo from "../components/StoresDemo.astro";
import RoutingDemo from "../components/RoutingDemo.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Astro JS POC</title>
    <ViewTransitions />
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        padding: 24px;
        font-family: system-ui, sans-serif;
        background: #fff;
        color: #111;
      }
      h1 {
        margin: 0 0 4px;
        font-size: 22px;
      }
      .subtitle {
        color: #666;
        font-size: 14px;
        margin: 0 0 24px;
      }
      .tabs {
        display: flex;
        gap: 6px;
        margin-bottom: 24px;
        border-bottom: 2px solid #eee;
        padding-bottom: 0;
        flex-wrap: wrap;
      }
      .tab {
        padding: 7px 14px;
        border: 2px solid transparent;
        border-bottom: none;
        border-radius: 6px 6px 0 0;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        background: transparent;
        position: relative;
        bottom: -2px;
        transition: all 0.15s;
      }
      .tab.active {
        border-color: #eee;
        border-bottom-color: #fff;
        background: #fff;
      }
      .tab[data-tab="islands"]   { color: #4a4; }
      .tab[data-tab="islands"].active   { border-color: #4a4;  border-bottom-color: #fff; }
      .tab[data-tab="hydration"] { color: #a84; }
      .tab[data-tab="hydration"].active { border-color: #a84;  border-bottom-color: #fff; }
      .tab[data-tab="list"]      { color: #e44; }
      .tab[data-tab="list"].active      { border-color: #e44;  border-bottom-color: #fff; }
      .tab[data-tab="content"]   { color: #48a; }
      .tab[data-tab="content"].active   { border-color: #48a;  border-bottom-color: #fff; }
      .tab[data-tab="slots"]     { color: #9a4; }
      .tab[data-tab="slots"].active     { border-color: #9a4;  border-bottom-color: #fff; }
      .tab[data-tab="stores"]    { color: #94a; }
      .tab[data-tab="stores"].active    { border-color: #94a;  border-bottom-color: #fff; }
      .tab[data-tab="routing"]   { color: #4ab; }
      .tab[data-tab="routing"].active   { border-color: #4ab;  border-bottom-color: #fff; }

      .panel { display: none; }
      .panel.active { display: block; }

      .island-compare,
      .list-compare {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
      }
      @media (max-width: 700px) {
        .island-compare, .list-compare { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <h1 transition:name="about-title">Astro JS POC</h1>
    <p class="subtitle">
      Islands Architecture &mdash; Static HTML by default, React islands on demand
    </p>

    <div class="tabs">
      <button class="tab active" data-tab="islands">Islands</button>
      <button class="tab" data-tab="hydration">Hydration</button>
      <button class="tab" data-tab="list">List</button>
      <button class="tab" data-tab="content">Content</button>
      <button class="tab" data-tab="slots">Slots</button>
      <button class="tab" data-tab="stores">Stores</button>
      <button class="tab" data-tab="routing">Routing</button>
    </div>

    <!-- Islands Tab -->
    <div class="panel active" data-panel="islands">
      <div class="island-compare">
        <StaticCounter />
        <ReactCounter client:load />
      </div>
    </div>

    <!-- Hydration Tab -->
    <div class="panel" data-panel="hydration">
      <HydrationDemo />
    </div>

    <!-- List Tab -->
    <div class="panel" data-panel="list">
      <div class="list-compare">
        <StaticList />
        <ReactList client:load />
      </div>
    </div>

    <!-- Content Tab -->
    <div class="panel" data-panel="content">
      <ContentDemo />
    </div>

    <!-- Slots Tab -->
    <div class="panel" data-panel="slots">
      <SlotsDemo />
    </div>

    <!-- Stores Tab -->
    <div class="panel" data-panel="stores">
      <StoresDemo />
    </div>

    <!-- Routing Tab -->
    <div class="panel" data-panel="routing">
      <RoutingDemo />
    </div>

    <script>
      const tabs = document.querySelectorAll<HTMLButtonElement>(".tab");
      const panels = document.querySelectorAll<HTMLDivElement>(".panel");

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.dataset.tab!;
          tabs.forEach((t) => t.classList.remove("active"));
          panels.forEach((p) => p.classList.remove("active"));
          tab.classList.add("active");
          document.querySelector(`[data-panel="${target}"]`)?.classList.add("active");
        });
      });
    </script>
  </body>
</html>
