---
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<div class="content-demo">
  <p class="intro">
    Content Collections provide type-safe access to markdown files.
    Schema validated at build time — bad frontmatter causes a build error, not a runtime crash.
  </p>

  <div class="schema-block">
    <strong>Schema (src/content/config.ts):</strong>
    <pre><code>{`const posts = defineCollection({
  type: "content",
  schema: z.object({
    title: z.string(),
    date: z.date(),
    tags: z.array(z.string()),
    draft: z.boolean().default(false),
  }),
});`}</code></pre>
  </div>

  <h4>Posts ({posts.length} total)</h4>
  <div class="post-list">
    {posts.map(post => (
      <div class="post-card">
        <div class="post-header">
          <span class="post-title">{post.data.title}</span>
          <span class="post-date">
            {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
          </span>
        </div>
        <div class="tags">
          {post.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <p class="slug">Slug: <code>{post.slug}</code></p>
      </div>
    ))}
  </div>

  <div class="note">
    <strong>Key point:</strong> This entire component — including the <code>getCollection()</code> call —
    runs at build time. Zero JS ships to the browser. The HTML above is baked into the page.
  </div>
</div>

<style>
  .content-demo {
    font-family: system-ui, sans-serif;
  }
  .intro {
    color: #555;
    font-size: 14px;
    margin-bottom: 20px;
  }
  .schema-block {
    background: #1e1e2e;
    color: #cdd6f4;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 24px;
    font-size: 13px;
  }
  .schema-block strong {
    color: #89b4fa;
    display: block;
    margin-bottom: 8px;
  }
  pre {
    margin: 0;
    overflow-x: auto;
  }
  code {
    font-family: "Fira Code", "Cascadia Code", monospace;
    font-size: 12px;
    line-height: 1.6;
  }
  h4 {
    margin: 0 0 12px;
    color: #333;
  }
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }
  .post-card {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 14px 16px;
    background: #fafafa;
  }
  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 8px;
  }
  .post-title {
    font-weight: 600;
    font-size: 14px;
    color: #222;
  }
  .post-date {
    font-size: 12px;
    color: #888;
    white-space: nowrap;
  }
  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .tag {
    background: #e8f0fe;
    color: #3367d6;
    font-size: 11px;
    padding: 2px 7px;
    border-radius: 10px;
  }
  .slug {
    font-size: 11px;
    color: #999;
    margin: 0;
  }
  .slug code {
    font-size: 11px;
    background: #eee;
    padding: 1px 4px;
    border-radius: 3px;
  }
  .note {
    background: #f0f4ff;
    border: 1px solid #c0ccff;
    border-radius: 8px;
    padding: 14px 16px;
    font-size: 13px;
    line-height: 1.5;
  }
  .note code {
    background: #dde5ff;
    padding: 1px 4px;
    border-radius: 3px;
    font-size: 12px;
  }
</style>
